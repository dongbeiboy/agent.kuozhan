{
  "name": "custom-agent-loader",
  "displayName": "Custom Agent Loader",
  "description": "Load custom .agent.md files as chat agents usable by runSubagent",
  "version": "0.1.4",
  "publisher": "kuozhan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dongbeiboy/agent.kuozhan.git"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:customAgentLoader.agentsView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "customAgentLoader.refresh",
        "title": "Custom Agent: Refresh Agent List",
        "icon": "$(refresh)"
      },
      {
        "command": "customAgentLoader.openAgentsFolder",
        "title": "Custom Agent: Open Agents Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "customAgentLoader.createNewAgent",
        "title": "Custom Agent: Create New Agent",
        "icon": "$(add)"
      },
      {
        "command": "customAgentLoader.listAgents",
        "title": "Custom Agent: List All Agents",
        "icon": "$(list-tree)"
      },
      {
        "command": "customAgentLoader.disableAgent",
        "title": "Custom Agent: Disable Agent",
        "icon": "$(circle-slash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "customAgentLoader",
          "title": "Custom Agents",
          "icon": "./images/agent.svg"
        }
      ]
    },
    "views": {
      "customAgentLoader": [
        {
          "type": "tree",
          "id": "customAgentLoader.agentsView",
          "name": "Custom Agents"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "customAgentLoader.refresh",
          "group": "navigation",
          "when": "view == customAgentLoader.agentsView"
        },
        {
          "command": "customAgentLoader.createNewAgent",
          "group": "navigation",
          "when": "view == customAgentLoader.agentsView"
        }
      ],
      "view/item/context": [
        {
          "command": "customAgentLoader.disableAgent",
          "group": "inline",
          "when": "view == customAgentLoader.agentsView && viewItem == agent-slot"
        }
      ]
    },
    "chatAgents": [
      {
        "path": "./static-slots/batch-worker.agent.md"
      }
    ],
    "configuration": {
      "title": "Custom Agent Loader",
      "properties": {
        "customAgentLoader.agentDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional directories (absolute paths) to scan for .agent.md files."
        },
        "customAgentLoader.staticDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "static-slots"
          ],
          "description": "Directories (relative to extension root) whose agents are statically declared in package.json chatAgents and CANNOT be disabled."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo ok",
    "compile": "npm run bump-build && tsc -p ./",
    "compile:ts": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "package:dev": "node scripts/dev-version.cjs",
    "bump-build": "node scripts/bump-build.cjs",
    "lint": "eslint src --ext ts"
  },
  "_patch": 8,
  "_baseVersion": "0.1",
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "@vscode/vsce": "^3.0.0"
  }
}
